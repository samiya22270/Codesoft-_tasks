LEVEL 3 – TASK 1: E-COMMERCE WEBSITE (Single Full Code)

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>E-Commerce Website</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      background:#f4f4f4;
      padding:20px;
    }

    h1{
      text-align:center;
      margin-bottom:20px;
      color:#1e3a8a;
    }

    .container{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:20px;
    }

    .product-card{
      background:white;
      padding:20px;
      border-radius:10px;
      box-shadow:0 0 10px rgba(0,0,0,0.1);
      text-align:center;
      transition:0.3s;
    }

    .product-card:hover{
      transform:scale(1.03);
    }

    .product-card img{
      width:100%;
      height:200px;
      object-fit:cover;
      border-radius:10px;
    }

    .product-card h2{
      margin:10px 0;
      color:#333;
    }

    .product-card p{
      color:#666;
      margin-bottom:10px;
    }

    button{
      padding:10px 15px;
      border:none;
      background:#2563eb;
      color:white;
      border-radius:5px;
      cursor:pointer;
    }

    button:hover{
      background:#1d4ed8;
    }

    .cart{
      margin-top:30px;
      background:white;
      padding:20px;
      border-radius:10px;
      box-shadow:0 0 10px rgba(0,0,0,0.1);
    }

    .cart h2{
      margin-bottom:15px;
    }

    #cartItems li{
      margin:10px 0;
    }

    #total{
      margin-top:15px;
      font-size:20px;
      color:green;
    }

  </style>

</head>

<body>

  <h1>E-Commerce Website</h1>

  <div class="container">

    <div class="product-card">
      <img src="https://images.unsplash.com/photo-1517336714739-489689fd1ca8?q=80&w=1000" alt="Laptop">
      <h2>Laptop</h2>
      <p>Price: ₹50000</p>
      <button onclick="addToCart('Laptop',50000)">Add to Cart</button>
    </div>

    <div class="product-card">
      <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?q=80&w=1000" alt="Phone">
      <h2>Smart Phone</h2>
      <p>Price: ₹20000</p>
      <button onclick="addToCart('Smart Phone',20000)">Add to Cart</button>
    </div>

    <div class="product-card">
      <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?q=80&w=1000" alt="Watch">
      <h2>Smart Watch</h2>
      <p>Price: ₹5000</p>
      <button onclick="addToCart('Smart Watch',5000)">Add to Cart</button>
    </div>

  </div>

  <div class="cart">

    <h2>Shopping Cart</h2>

    <ul id="cartItems"></ul>

    <h3 id="total">Total: ₹0</h3>

    <button onclick="checkout()">Proceed to Checkout</button>

  </div>

  <script>

    let total = 0;

    function addToCart(product, price){

      const cartItems = document.getElementById("cartItems");

      const li = document.createElement("li");

      li.innerText = product + " - ₹" + price;

      cartItems.appendChild(li);

      total += price;

      document.getElementById("total").innerText = "Total: ₹" + total;

      alert(product + " added to cart");

    }

    function checkout(){

      if(total === 0){
        alert("Your cart is empty");
      }
      else{
        alert("Order placed successfully!\nTotal Amount: ₹" + total);
      }

    }

  </script>

</body>
</html>
